# Flask configuration
FLASK_SECRET_KEY=your-secret-key-here

# MySQL Database URI
DATABASE_URI=mysql+pymysql://root:your-password@localhost/ats

# Log file path
LOG_PATH=./LOG/app.log

# AWS credentials for S3 and DynamoDB
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-west-1

# S3 bucket names
S3_RESUME_BUCKET=your-resume-bucket-name
S3_DYNAMO_BUCKET=your-dynamo-bucket-name

# DynamoDB table name
DYNAMO_TABLE_NAME=cmpeats

# Email configuration (SMTP)
EMAIL_SENDER_ADDRESS=your-email@gmail.com
EMAIL_SENDER_PASSWORD=your-email-app-password

# Admin seed passwords (used by create_admin.py)
ADMIN_PASSWORD=changeme
ADMIN_PASSWORD_2=changeme
